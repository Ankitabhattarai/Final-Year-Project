{
  "info": {
    "name": "Careline API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": [""]
        }
      },
      "response": []
    },
    {
      "name": "Login Test (Fail intentionally to test validation)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"doesnotexist@test.com\",\"password\":\"wrongpassword\"}"
        },
        "url": {
          "raw": "http://localhost:5000/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 or 401', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 401, 404]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Fetch Hospitals List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/patient-dashboard/hospitals",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "patient-dashboard", "hospitals"]
        }
      },
      "event": [
         {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 401 Unauthorized (Protected Route Demo)', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
